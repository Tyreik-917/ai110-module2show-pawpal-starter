classDiagram
    %% PawPal+ — final implementation (pawpal_system.py).
    %% Owner 1..* Pet 1..* Task (bidirectional back-reference on Task).
    %% Scheduler is STATELESS: it operates on an Owner instead of holding tasks.

    class Owner {
        -str name
        -Pet[] pets
        +set_name(str name) void
        +get_name() str
        +add_pet(Pet pet) Pet
        +get_pets() Pet[]
        +get_all_tasks() tuple[Pet, Task][]
    }

    class Pet {
        -str name
        -str species
        -Task[] tasks
        +set_name(str name) void
        +get_name() str
        +add_task(Task task) Task
        +remove_task(Task task) void
        +get_tasks() Task[]
        +pending_tasks() Task[]
    }

    class Task {
        -str description
        -int duration
        -str frequency
        -str priority
        -bool completed
        -str time
        -date last_completed
        -Pet _pet
        +edit(...) void
        +mark_complete(date on_date) Task
        +mark_incomplete() void
        +next_occurrence(date completion_date) Task
        +due_today(date today) bool
        +priority_rank() int
        +to_dict() dict
    }

    class Scheduler {
        +complete_task(Pet pet, Task task, date on_date) Task
        +filter_tasks(Owner owner, bool completed, str pet_name) tuple[]
        +collect_tasks(Owner owner, bool include_completed, date today) tuple[]
        +organize(tuple[] pairs, str by) tuple[]
        +find_conflicts(tuple[] pairs) tuple[]
        +conflict_warnings(Owner owner, date today) str[]
        +generate_schedule(Owner owner, int available_minutes, bool include_completed, date today) dict[]
    }

    %% Module-level helpers (not a class): parse_time(), to_minutes(),
    %% constants PRIORITY_RANK, MINUTES_IN_DAY.

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Task "*" --> "1" Pet : belongs to (_pet back-ref)
    Scheduler ..> Owner : plans for
    Scheduler ..> Pet : reads
    Scheduler ..> Task : orders / completes
